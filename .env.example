# Copy this file to ".env" and fill in real values.
# .env is gitignored — never commit real keys.

# --- LLM provider key(s) ---
# Answer generation uses Google Gemini (free tier). Get a free key at:
#   https://aistudio.google.com/apikey
# litellm reads this exact variable name automatically.
GEMINI_API_KEY=your_free_gemini_key_here

# (legacy / optional — not used right now)
# OPENAI_API_KEY=sk-...

# --- Model selection (override the defaults in app/config.py) ---
# Swap these to change models WITHOUT editing code — that's the gateway's job.
LLM_SYNTHESIS_MODEL=gemini/gemini-1.5-flash
LLM_EXTRACTION_MODEL=gemini/gemini-1.5-flash
# Embeddings are local (no key); leave as-is.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval knobs (optional) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5

DEBUG=true
